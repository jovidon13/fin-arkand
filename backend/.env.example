# ARKAND Finance — backend environment (copy to backend/.env for local dev)
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
DATABASE_URL=postgres://arkand:arkand@localhost:5432/arkand
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CORS_ALLOWED_ORIGINS=http://localhost:5173
OWNER_APPROVALS_REQUIRED=3

# Local-only convenience: run management checks/tests on sqlite instead of Postgres.
# USE_SQLITE=1
