# ARKAND Finance — backend environment.
# Local dev: copy to backend/.env. Production (Railway): set these as service
# variables in the Railway dashboard (do NOT commit real secrets).

# --- Core ---------------------------------------------------------------------
# Long random string. Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-in-production
# 1/true for local dev, 0/false in production.
DJANGO_DEBUG=1
# Comma-separated hostnames. On Railway the public domain is auto-trusted, so
# "*" (or leaving the default) is fine; tighten to your domain if you prefer.
DJANGO_ALLOWED_HOSTS=*

# --- Database -----------------------------------------------------------------
# Local Postgres. On Railway, add the Postgres plugin and reference its variable:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgres://arkand:arkand@localhost:5432/arkand

# --- CORS / CSRF (let the Vercel frontend call this API) ----------------------
# Exact SPA origin(s), comma-separated. Use your Vercel production URL in prod:
#   CORS_ALLOWED_ORIGINS=https://arkand-finance.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Optional: allow Vercel preview deployments by regex.
# CORS_ALLOWED_ORIGIN_REGEXES=^https://.*\.vercel\.app$
# Needed for Django admin login over HTTPS (add your backend + frontend origins):
# CSRF_TRUSTED_ORIGINS=https://your-backend.up.railway.app,https://arkand-finance.vercel.app

# --- Celery (optional; only if you add a Redis plugin + worker service) --------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Domain -------------------------------------------------------------------
OWNER_APPROVALS_REQUIRED=3

# --- Deploy toggles (read by entrypoint.sh) -----------------------------------
# RUN_MIGRATIONS defaults to 1 (web service applies migrations on boot).
# Seed demo data on first boot (owners/roles/sample finance data): SEED_DEMO=1
# SEED_DEMO=0

# Local-only convenience: run management checks/tests on sqlite instead of Postgres.
# USE_SQLITE=1
