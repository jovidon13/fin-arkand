# ARKAND Finance — docker-compose environment (copy to .env)
POSTGRES_DB=arkand
POSTGRES_USER=arkand
POSTGRES_PASSWORD=arkand

DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*
CORS_ALLOWED_ORIGINS=http://localhost:8080

# Seed demo data on first boot of the backend container (1 = yes).
SEED_DEMO=1
