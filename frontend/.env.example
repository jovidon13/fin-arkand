# ARKAND Finance — frontend environment.
# Local dev: copy to frontend/.env.local (optional). Production (Vercel): set
# these in Project Settings → Environment Variables.
#
# NOTE: Vite inlines VITE_* vars at BUILD time, so a change requires a redeploy.

# Base URL of the backend API, INCLUDING the /api/v1 prefix.
# Production (point at your Railway backend):
#   VITE_API_URL=https://your-backend.up.railway.app/api/v1
# Local dev: leave unset — the Vite dev server proxies /api to http://localhost:8000
# (see vite.config.ts), so the app falls back to the "/api/v1" relative path.
# VITE_API_URL=https://your-backend.up.railway.app/api/v1

# Local dev only: override the backend the Vite dev server proxies /api to.
# VITE_API_PROXY=http://localhost:8000
